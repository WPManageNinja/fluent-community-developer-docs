{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/courses/{course_slug}/lessons/{lesson_slug}/by-slug": {
      "get": {
        "operationId": "getLessonBySlug",
        "summary": "GET Get Lesson By Slug",
        "description": "Get Lesson By Slug for the FluentCommunity Courses API.\n\nController: `CourseController@getLessonBySlug`\nRoute source: `fluent-community/Modules/Course/Http/course_api.php:11`",
        "tags": [
          "Courses"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "course_slug",
            "in": "path",
            "required": true,
            "description": "Course Slug extracted from the URL path.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lesson_slug",
            "in": "path",
            "required": true,
            "description": "Lesson Slug extracted from the URL path.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lesson": {
                      "type": "string",
                      "nullable": true
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "lesson": null
                }
              }
            }
          },
          "422": {
            "description": "You must need to be invited to view this course",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "You must need to be invited to view this course"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
