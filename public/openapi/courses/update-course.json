{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/admin/courses/{course_id}": {
      "put": {
        "operationId": "updateCourse",
        "summary": "PUT Update Course",
        "description": "Update Course for the FluentCommunity Courses API.\n\nController: `CourseAdminController@updateCourse`\nRoute source: `fluent-community/Modules/Course/Http/course_api.php:21`",
        "tags": [
          "Courses"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "description": "Course ID extracted from the URL path.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "privacy": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "cover_photo": {
                    "type": "string"
                  },
                  "parent_id": {
                    "type": "string"
                  },
                  "slug": {
                    "type": "string"
                  },
                  "created_by": {
                    "type": "string"
                  },
                  "course_type": {
                    "type": "string"
                  },
                  "settings": {
                    "type": "object",
                    "properties": {
                      "custom_lock_screen": {
                        "type": "string"
                      },
                      "onboard_redirect_url": {
                        "type": "string"
                      },
                      "emoji": {
                        "type": "string"
                      },
                      "shape_svg": {
                        "type": "string"
                      },
                      "disable_comments": {
                        "type": "string"
                      },
                      "hide_members_count": {
                        "type": "string"
                      },
                      "hide_instructor_view": {
                        "type": "string"
                      },
                      "show_instructor_students_count": {
                        "type": "string"
                      },
                      "show_paywalls": {
                        "type": "string"
                      },
                      "course_layout": {
                        "type": "string"
                      },
                      "course_details": {
                        "type": "string"
                      },
                      "public_lesson_view": {
                        "type": "string"
                      }
                    },
                    "required": []
                  },
                  "category_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "meta_settings": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "title",
                  "privacy",
                  "description",
                  "status",
                  "course_type"
                ]
              },
              "example": {
                "title": "",
                "privacy": "",
                "description": "",
                "status": "",
                "cover_photo": "",
                "parent_id": "",
                "slug": "",
                "created_by": "",
                "course_type": "",
                "settings": {
                  "custom_lock_screen": "",
                  "onboard_redirect_url": "",
                  "emoji": "",
                  "shape_svg": "",
                  "disable_comments": "",
                  "hide_members_count": "",
                  "hide_instructor_view": "",
                  "show_instructor_students_count": "",
                  "show_paywalls": "",
                  "course_layout": "",
                  "course_details": "",
                  "public_lesson_view": ""
                },
                "category_ids": [],
                "meta_settings": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "nullable": false
                    },
                    "course": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "message": "Course has been updated successfully.",
                  "course": {
                    "id": 0
                  }
                }
              }
            }
          },
          "422": {
            "description": "Course Redirect URL is not valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Course Redirect URL is not valid"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
