{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/admin/courses/{course_id}/students": {
      "get": {
        "operationId": "listCourseStudents",
        "summary": "GET List Course Students",
        "description": "List Course Students for the FluentCommunity Courses API.\n\nController: `CourseAdminController@getCourseStudents`\nRoute source: `fluent-community/Modules/Course/Http/course_api.php:25`",
        "tags": [
          "Courses"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "description": "Course ID extracted from the URL path.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Search read via `$request->getSafe()` in getCourseStudents().",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "students": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "user_id": {
                                "type": "integer"
                              },
                              "display_name": {
                                "type": "string",
                                "nullable": false
                              },
                              "username": {
                                "type": "string",
                                "nullable": false
                              },
                              "avatar": {
                                "type": "string",
                                "nullable": false
                              },
                              "status": {
                                "type": "string",
                                "nullable": false
                              },
                              "total_points": {
                                "type": "integer"
                              },
                              "is_verified": {
                                "type": "boolean"
                              },
                              "meta": {
                                "type": "object",
                                "properties": {
                                  "website": {
                                    "type": "string",
                                    "nullable": false
                                  },
                                  "cover_photo": {
                                    "type": "string",
                                    "nullable": false
                                  },
                                  "badge_slug": {
                                    "type": "array",
                                    "items": {
                                      "type": "string",
                                      "nullable": false
                                    }
                                  },
                                  "social_links": {
                                    "type": "object",
                                    "properties": {
                                      "instagram": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "twitter": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "youtube": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "linkedin": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "fb": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "blue_sky": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "tiktok": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "pinterest": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "telegram": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "snapchat": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "reddit": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "twitch": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "vk": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "github": {
                                        "type": "string",
                                        "nullable": false
                                      },
                                      "mastodon": {
                                        "type": "string",
                                        "nullable": false
                                      }
                                    },
                                    "additionalProperties": false
                                  }
                                },
                                "additionalProperties": false
                              },
                              "created_at": {
                                "type": "string",
                                "nullable": false
                              },
                              "short_description": {
                                "type": "string",
                                "nullable": false
                              },
                              "last_activity": {
                                "type": "string",
                                "nullable": false
                              },
                              "badge": {
                                "type": "string",
                                "nullable": false
                              },
                              "permalink": {
                                "type": "string",
                                "nullable": false
                              }
                            },
                            "additionalProperties": false
                          }
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "from": {
                          "type": "integer"
                        },
                        "to": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "has_more": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "students": {
                    "data": [
                      {
                        "user_id": 0,
                        "display_name": "",
                        "username": "",
                        "avatar": "",
                        "status": "",
                        "total_points": 0,
                        "is_verified": false,
                        "meta": {
                          "website": "",
                          "cover_photo": "",
                          "badge_slug": [
                            ""
                          ],
                          "social_links": {
                            "instagram": "",
                            "twitter": "",
                            "youtube": "",
                            "linkedin": "",
                            "fb": "",
                            "blue_sky": "",
                            "tiktok": "",
                            "pinterest": "",
                            "telegram": "",
                            "snapchat": "",
                            "reddit": "",
                            "twitch": "",
                            "vk": "",
                            "github": "",
                            "mastodon": ""
                          }
                        },
                        "created_at": "2026-01-01 00:00:00",
                        "short_description": "",
                        "last_activity": "2026-01-01 00:00:00",
                        "badge": "",
                        "permalink": ""
                      }
                    ],
                    "current_page": 1,
                    "per_page": 10,
                    "from": 1,
                    "to": 1,
                    "total": 1,
                    "last_page": 1,
                    "has_more": false
                  }
                }
              }
            }
          },
          "422": {
            "description": "Request validation or permission error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Request validation or permission error."
                }
              }
            }
          }
        }
