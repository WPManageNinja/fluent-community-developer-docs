{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/courses/{course_id}/lessons/{lesson_id}/video-watched": {
      "post": {
        "operationId": "postMarkLessonVideoWatched",
        "summary": "POST Post Mark Lesson Video Watched",
        "description": "Post Mark Lesson Video Watched for the FluentCommunity Courses API.\n\nController: `CourseController@markLessonVideoWatched`\nRoute source: `fluent-community/Modules/Course/Http/course_api.php:16`",
        "tags": [
          "Courses"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "description": "Course ID extracted from the URL path.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lesson_id",
            "in": "path",
            "required": true,
            "description": "Lesson ID extracted from the URL path.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "watched_percent": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "watched_percent": ""
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "nullable": false
                    },
                    "is_gated": {
                      "type": "boolean"
                    },
                    "watched": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "message": "Video watch progress has been recorded.",
                  "is_gated": true,
                  "watched": true
                }
              }
            }
          },
          "422": {
            "description": "Please watch at least %d%% of the video.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Please watch at least %d%% of the video."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
