{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/spaces/space_groups/{id}": {
      "put": {
        "operationId": "updateSpaceGroup",
        "summary": "PUT Update Space Group",
        "description": "Update Space Group for the FluentCommunity Spaces API.\n\nController: `SpaceController@updateSpaceGroup`\nRoute source: `fluent-community/app/Http/Routes/api.php:33`",
        "tags": [
          "Spaces"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID extracted from the URL path.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "settings": {
                    "type": "object",
                    "properties": {
                      "always_show_spaces": {
                        "type": "string"
                      }
                    },
                    "required": []
                  },
                  "title": {
                    "type": "string"
                  }
                },
                "required": [
                  "title"
                ]
              },
              "example": {
                "settings": {
                  "always_show_spaces": ""
                },
                "title": ""
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "nullable": false
                    },
                    "group": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "created_by": {
                          "type": "integer"
                        },
                        "parent_id": {
                          "type": "integer"
                        },
                        "title": {
                          "type": "string",
                          "nullable": false
                        },
                        "slug": {
                          "type": "string",
                          "nullable": false
                        },
                        "description": {
                          "type": "string",
                          "nullable": false
                        },
                        "logo": {
                          "type": "string",
                          "nullable": false
                        },
                        "cover_photo": {
                          "type": "string",
                          "nullable": false
                        },
                        "type": {
                          "type": "string",
                          "nullable": false
                        },
                        "privacy": {
                          "type": "string",
                          "nullable": false
                        },
                        "status": {
                          "type": "string",
                          "nullable": false
                        },
                        "serial": {
                          "type": "integer"
                        },
                        "settings": {
                          "type": "object",
                          "properties": {
                            "hide_members": {
                              "type": "string",
                              "nullable": false
                            },
                            "always_show_spaces": {
                              "type": "string",
                              "nullable": false
                            }
                          },
                          "additionalProperties": false
                        },
                        "created_at": {
                          "type": "string",
                          "nullable": false
                        },
                        "updated_at": {
                          "type": "string",
                          "nullable": false
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "message": "Space group has been updated",
                  "group": {
                    "id": 0,
                    "created_by": 0,
                    "parent_id": 0,
                    "title": "",
                    "slug": "",
                    "description": "",
                    "logo": "",
                    "cover_photo": "",
                    "type": "",
                    "privacy": "",
                    "status": "",
                    "serial": 0,
                    "settings": {
                      "hide_members": "no",
                      "always_show_spaces": "yes"
                    },
                    "created_at": "2026-01-01 00:00:00",
                    "updated_at": "2026-01-01 00:00:00"
                  }
                }
              }
            }
          },
          "422": {
            "description": "The title is already taken. Please use a different title",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "The title is already taken. Please use a different title"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
