            "required": true,
            "description": "SpaceSlug extracted from the URL path.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Search read via `$request->getSafe()` in getMembers().",
