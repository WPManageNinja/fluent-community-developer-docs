          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Search read via `$request->getSafe()` in searchSpace().",
            "schema": {
              "type": "string"
            }
          }
        ],
