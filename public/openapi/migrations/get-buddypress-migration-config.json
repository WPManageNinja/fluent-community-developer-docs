{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/migrations/buddypress/config": {
      "get": {
        "operationId": "getBuddypressMigrationConfig",
        "summary": "GET Get Buddypress Migration Config",
        "description": "Get Buddypress Migration Config for the FluentCommunity Migrations API.\n\nController: `BPMigrationController@getMigrationConfig`\nRoute source: `fluent-community/Modules/Migrations/Http/migration_api.php:12`",
        "tags": [
          "Migrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupItems": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "featureConfig": {
                      "type": "object",
                      "properties": {
                        "has_groups": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false
                    },
                    "stats": {
                      "type": "string",
                      "nullable": true
                    },
                    "current_status": {
                      "type": "string",
                      "nullable": true
                    },
                    "has_previous": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "groupItems": [],
                  "featureConfig": {
                    "has_groups": false
                  },
                  "stats": null,
                  "current_status": null,
                  "has_previous": false
                }
              }
            }
          },
          "422": {
            "description": "Request validation or permission error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Request validation or permission error."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
