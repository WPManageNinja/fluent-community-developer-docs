{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/feeds/ticker": {
      "get": {
        "operationId": "getFeedTicker",
        "summary": "GET Get Feed Ticker",
        "description": "Get Feed Ticker for the FluentCommunity Feeds API.\n\nController: `FeedsController@getTicker`\nRoute source: `fluent-community/app/Http/Routes/api.php:63`",
        "tags": [
          "Feeds"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "since",
            "in": "query",
            "required": false,
            "description": "Since read via `$request->get()` in getTicker().",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "timestamp": {
                      "type": "string",
                      "nullable": false
                    },
                    "has_changes": {
                      "type": "boolean"
                    },
                    "feeds": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "notifications": {
                      "type": "object",
                      "properties": {
                        "unread_count": {
                          "type": "integer"
                        },
                        "new_count": {
                          "type": "integer"
                        }
                      },
                      "additionalProperties": false
                    },
                    "spaces": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "execution_time": {
                      "type": "number"
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "timestamp": "2026-01-01 00:00:00",
                  "has_changes": false,
                  "feeds": [],
                  "notifications": {
                    "unread_count": 0,
                    "new_count": 0
                  },
                  "spaces": [],
                  "execution_time": 0.123
                }
              }
            }
          },
          "422": {
            "description": "Request validation or permission error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Request validation or permission error."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
