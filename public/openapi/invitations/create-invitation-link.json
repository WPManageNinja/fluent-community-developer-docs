{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/invitations/link": {
      "post": {
        "operationId": "createInvitationLink",
        "summary": "POST Create Invitation Link",
        "description": "Create Invitation Link for the FluentCommunity Invitations API.\n\nController: `InvitationController@createNewLink`\nRoute source: `fluent-community/Modules/Auth/InvitationModule.php:26`",
        "tags": [
          "Invitations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "space_id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer"
                  },
                  "expire_date": {
                    "type": "string"
                  }
                },
                "required": [
                  "space_id",
                  "title"
                ]
              },
              "example": {
                "space_id": "",
                "title": "",
                "limit": 0,
                "expire_date": ""
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "nullable": false
                    },
                    "invitation": {
                      "type": "string",
                      "nullable": true
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "message": "Invitation link has been created",
                  "invitation": null
                }
              }
            }
          },
          "422": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Error response"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
