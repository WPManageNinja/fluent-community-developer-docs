{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/invitations": {
      "get": {
        "operationId": "listInvitations",
        "summary": "GET List Invitations",
        "description": "List Invitations for the FluentCommunity Invitations API.\n\nController: `InvitationController@getInvitations`\nRoute source: `fluent-community/Modules/Auth/InvitationModule.php:23`",
        "tags": [
          "Invitations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "space_id",
            "in": "query",
            "required": false,
            "description": "Space ID read via `$request->get()` in getInvitations().",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Status read via `$request->get()` in getInvitations().",
            "schema": {
              "type": "string",
              "default": "pending"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "invitations": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "additionalProperties": true
                          }
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "from": {
                          "type": "integer"
                        },
                        "to": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "has_more": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false
                    },
                    "is_mod": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "invitations": {
                    "data": [],
                    "current_page": 1,
                    "per_page": 10,
                    "from": 0,
                    "to": 0,
                    "total": 0,
                    "last_page": 0,
                    "has_more": false
                  },
                  "is_mod": false
                }
              }
            }
          },
          "422": {
            "description": "Request validation or permission error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Request validation or permission error."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
