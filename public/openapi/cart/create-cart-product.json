{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/cart/products/create": {
      "post": {
        "operationId": "createCartProduct",
        "summary": "POST Create Cart Product",
        "description": "Create Cart Product for the FluentCommunity Cart Integration API.\n\nController: `PaywallController@createProduct`\nRoute source: `fluent-community/Modules/Integrations/FluentCart/Http/cart_api.php:12`",
        "tags": [
          "Cart Integration"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "price": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "title": "",
                "price": ""
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "product": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "title": {
                          "type": "string",
                          "nullable": false
                        },
                        "image": {
                          "type": "string",
                          "nullable": false
                        },
                        "price": {
                          "type": "string",
                          "nullable": true
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "product": {
                    "id": 0,
                    "title": "",
                    "image": "",
                    "price": null
                  }
                }
              }
            }
          },
          "422": {
            "description": "Failed to create product",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Failed to create product"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
