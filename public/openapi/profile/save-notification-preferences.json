{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCommunity API",
    "description": "Complete REST API documentation for FluentCommunity — a WordPress community and forum plugin.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-community/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/profile/{username}/notification-preferences": {
      "post": {
        "operationId": "saveNotificationPreferences",
        "summary": "POST Save Notification Preferences",
        "description": "Save Notification Preferences for the FluentCommunity Profile API.\n\nController: `ProfileController@saveNotificationPreferance`\nRoute source: `fluent-community/app/Http/Routes/api.php:92`",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "description": "Username extracted from the URL path.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_globals": {
                    "type": "object",
                    "properties": {
                      "message_email_frequency": {
                        "type": "string"
                      }
                    },
                    "required": []
                  },
                  "space_prefs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "example": {
                "user_globals": {
                  "message_email_frequency": ""
                },
                "space_prefs": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "prefs": {
                      "type": "string",
                      "nullable": true
                    },
                    "message": {
                      "type": "string",
                      "nullable": false
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "prefs": null,
                  "message": "Email Notification preferences have been updated"
                }
              }
            }
          },
          "422": {
            "description": "Request validation or permission error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Request validation or permission error."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with username:application_password."
      }
    }
  }
}
